POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aegisx
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

AEGISX_DEMO_MODE=true
AEGISX_SESSION_SECRET=change_this_in_production
AEGISX_LOG_LEVEL=INFO

# CORS — Comma-separated allowed origins (restrict in production)
AEGISX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,https://aegisx-2026.web.app,https://aegisx-2026.firebaseapp.com,https://aegisx-backend-t1v7.onrender.com

# WebSocket rate limiting (per user)
AEGISX_WS_RATE_LIMIT=5
AEGISX_WS_RATE_BURST=10
